{
  "name": "@digitalbazaar/edv-client",
  "version": "16.3.1-0",
  "description": "JavaScript Encrypted Data Vault",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.md\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run lint && pnpm run test:node && pnpm run test:browser",
    "test:browser": "playwright test",
    "test:node": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@digitalbazaar/http-client": "^4.0.0",
    "@digitalbazaar/http-signature-zcap-invoke": "^6.0.0",
    "@digitalbazaar/lru-memoize": "^4.0.0",
    "@digitalbazaar/minimal-cipher": "^6.0.0",
    "@noble/hashes": "^2.2.0",
    "base58-universal": "^2.0.0",
    "base64url-universal": "^2.0.0",
    "canonicalize": "^2.0.0",
    "split-string": "^6.1.0"
  },
  "peerDependencies": {
    "react-native-get-random-values": "^1.11.0"
  },
  "peerDependenciesMeta": {
    "react-native-get-random-values": {
      "optional": true
    }
  },
  "devDependencies": {
    "@digitalbazaar/did-method-key": "^5.1.0",
    "@digitalbazaar/ecdsa-multikey": "^1.5.0",
    "@digitalbazaar/ed25519-signature-2020": "^5.2.0",
    "@digitalbazaar/ed25519-verification-key-2020": "^4.1.0",
    "@digitalbazaar/security-document-loader": "^3.0.1",
    "@digitalbazaar/x25519-key-agreement-key-2020": "^3.0.1",
    "@digitalbazaar/zcap": "^9.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.11.0",
    "chai": "^4.3.6",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsonld-signatures": "^11.2.1",
    "path-to-regexp": "^6.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "route-params": "^0.2.0",
    "sinon": "^17.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "uuid": "^9.0.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalbazaar/edv-client"
  },
  "keywords": [
    "edv",
    "edv client",
    "encrypted data vault",
    "encrypted data vault client",
    "data hub",
    "datahub"
  ],
  "author": {
    "name": "Digital Bazaar, Inc.",
    "email": "support@digitalbazaar.com",
    "url": "https://digitalbazaar.com/"
  },
  "bugs": {
    "url": "https://github.com/digitalbazaar/edv-client/issues"
  },
  "homepage": "https://github.com/digitalbazaar/edv-client",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
